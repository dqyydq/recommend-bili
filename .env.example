# Generate once with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
POSTGRES_USER=bookmark
POSTGRES_PASSWORD=change-this-before-starting
POSTGRES_DB=bookmark_agent
POSTGRES_PORT=15433
DATABASE_URL=postgresql://bookmark:change-this-before-starting@localhost:15433/bookmark_agent

# Set true behind HTTPS in production. Keep false only for local HTTP development.
COOKIE_SECURE=false
SESSION_TTL_SECONDS=604800

# Comma-separated browser origins allowed to send credentialed requests.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Chat model. The API key is normally entered in the encrypted in-app settings.
# Any OpenAI-compatible endpoint can be used.
MODEL_BASE_URL=https://api.deepseek.com

# Embeddings do not require Ollama. fastembed runs locally and falls back to hashing.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=

# Let users enter a seeded local demo without a Bilibili account or model key.
DEMO_MODE=false

# Local draft scheduler. It never executes Bilibili mutations.
PROACTIVE_INTERVAL_SECONDS=3600
