# Generate once with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
POSTGRES_USER=bookmark
POSTGRES_PASSWORD=change-this-before-starting
POSTGRES_DB=bookmark_agent
POSTGRES_PORT=15433
DATABASE_URL=postgresql://bookmark:change-this-before-starting@localhost:15433/bookmark_agent

# Set true behind HTTPS in production. Keep false only for local HTTP development.
COOKIE_SECURE=false
SESSION_TTL_SECONDS=604800

# Comma-separated browser origins allowed to send credentialed requests.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
